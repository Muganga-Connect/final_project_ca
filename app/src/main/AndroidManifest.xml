<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".MugangaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Appointment_Schedule">
        
        <!-- Splash Screen - Launcher Activity -->
        <activity
            android:name=".activity.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Appointment_Schedule.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Main Activities -->
        <activity
            android:name=".activity.MainActivity"
            android:exported="true" />
        <activity
            android:name=".activity.LoginActivity"
            android:exported="true" />
        <activity
            android:name=".activity.SignUpActivity"
            android:exported="true" />
        <activity
            android:name=".activity.AIAssistantActivity"
            android:exported="true" />
        <activity
            android:name=".activity.ProfileActivity"
            android:exported="true" />
        
        <!-- Management Activities -->
        <activity
            android:name=".activity.AppointmentManagementActivity"
            android:exported="true" />
        <activity
            android:name=".activity.AppointmentHistoryActivity"
            android:exported="true" />
        <activity
            android:name=".activity.SecurityPinActivity"
            android:exported="true" />
        <activity
            android:name=".activity.PersonalInformationActivity"
            android:exported="true" />
        <activity
            android:name=".activity.NotificationPreferencesActivity"
            android:exported="true" />
        
    </application>

</manifest>