        android:fillColor="@color/splash_accent_orange"
        android:pathData="M20,30 m-3,0 a3,3 0,1,1 6,0 a3,3 0,1,1 -6,0 M100,30 m-3,0 a3,3 0,1,1 6,0 a3,3 0,1,1 -6,0 M20,90 m-3,0 a3,3 0,1,1 6,0 a3,3 0,1,1 -6,0 M100,90 m-3,0 a3,3 0,1,1 6,0 a3,3 0,1,1 -6,0"/>
    
    <!-- Connection lines -->
    <path
        android:strokeColor="@color/splash_accent_orange"
        android:strokeWidth="2"
        android:fillColor="@android:color/transparent"
        android:pathData="M20,30 L60,55 L100,30 M20,90 L60,65 L100,90"/>
