<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.MugangaConnect" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryVariant">@color/blue_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/bg_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="EditTextLabel" parent="TextAppearance.AppCompat.Small">
        <item name="android:textColor">@color/text_dark</item>
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="MugangaActionButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_height">56dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>
</resources>