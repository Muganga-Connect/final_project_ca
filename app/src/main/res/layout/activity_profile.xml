<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <ScrollView
        android:id="@+id/profileScroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Profile Header Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center_horizontal">

                    <!-- Language Selector button — text set dynamically in ProfileActivity -->
                    <TextView
                        android:id="@+id/languageSelector"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/language_label"
                        android:textSize="14sp"
                        android:textColor="@color/text_dark"
                        android:background="@drawable/bg_edittext"
                        android:padding="8dp"
                        android:layout_gravity="end"
                        android:layout_marginBottom="16dp"
                        android:clickable="true"
                        android:focusable="true"/>

                    <!-- Profile Image -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        app:cardCornerRadius="50dp"
                        app:cardElevation="0dp">
                        <ImageView
                            android:id="@+id/profileImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:src="@drawable/user"
                            android:scaleType="centerCrop"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Name -->
                    <TextView
                        android:id="@+id/profileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alexandrine Mukamana"
                        android:textSize="20sp"
                        android:textColor="@color/text_dark"
                        android:textStyle="bold"
                        android:layout_marginTop="16dp"/>

                    <!-- Patient ID label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/patient_id_label"
                        android:textSize="14sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:id="@+id/patientId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PN-10293"
                        android:textSize="16sp"
                        android:textColor="@color/blue_primary"
                        android:textStyle="bold"/>

                    <!-- Edit Button -->
                    <TextView
                        android:id="@+id/editProfileBtn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/edit_btn"
                        android:textSize="14sp"
                        android:textColor="@color/blue_primary"
                        android:background="@drawable/bg_tab_selected"
                        android:paddingHorizontal="32dp"
                        android:paddingVertical="8dp"
                        android:layout_marginTop="16dp"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Health Snapshot -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/health_snapshot"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Weight Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_field_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="⚖️"
                        android:textSize="20sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/weight_label"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"/>
                        <TextView
                            android:id="@+id/weightValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="68.4 kg"
                            android:textSize="16sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Blood Type Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_field_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="💧"
                        android:textSize="20sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/blood_type_label"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"/>
                        <TextView
                            android:id="@+id/bloodTypeValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="O+"
                            android:textSize="16sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Emergency Contact Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/blue_field_bg">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="🚨"
                        android:textSize="20sp"
                        android:gravity="center"/>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/emergency_label"
                            android:textSize="11sp"
                            android:textColor="@color/text_hint"/>
                        <TextView
                            android:id="@+id/emergencyValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+250 788 123 456"
                            android:textSize="16sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Account Settings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/account_settings"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Personal Information -->
            <LinearLayout
                android:id="@+id/personalInfoItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="👤"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/personal_information"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>

            <!-- Security & PIN -->
            <LinearLayout
                android:id="@+id/securityPinItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🛡️"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/security_pin"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>

            <!-- Notification Preferences -->
            <LinearLayout
                android:id="@+id/notificationItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔔"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/notification_preferences"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>

            <!-- Manage Reminders -->
            <LinearLayout
                android:id="@+id/remindersItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📋"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/manage_reminders"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="24sp"
                    android:textColor="@color/text_hint"/>
            </LinearLayout>

            <!-- Enable Biometrics -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔒"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/enable_biometrics"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/biometricSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <!-- Support -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/support"
                android:textSize="18sp"
                android:textColor="@color/text_dark"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Help Center -->
            <LinearLayout
                android:id="@+id/helpCenterItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="❓"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/help_center"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Privacy Policy -->
            <LinearLayout
                android:id="@+id/privacyPolicyItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔐"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/privacy_policy"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Terms of Service -->
            <LinearLayout
                android:id="@+id/termsItem"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:layout_marginBottom="24dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">
                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📄"
                    android:textSize="20sp"
                    android:gravity="center"/>
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/terms_of_service"
                    android:textSize="15sp"
                    android:textColor="@color/text_dark"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>

            <!-- Log Out Button -->
            <TextView
                android:id="@+id/logoutBtn"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/log_out"
                android:textSize="16sp"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:background="@drawable/bg_edittext"
                android:padding="16dp"
                android:gravity="center"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                android:focusable="true"/>

        </LinearLayout>
    </ScrollView>

    <include
        layout="@layout/include_bottom_nav"
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
