<?xml version="1.0" encoding="utf-8"?>
<resources>
<style name="ChipStyle">
    <item name="android:background">@drawable/bg_chip</item>
    <item name="android:padding">10dp</item>
    <item name="android:layout_marginEnd">8dp</item>
</style>

<style name="DeptItem">
<item name="android:background">@drawable/bg_dept</item>
<item name="android:padding">12dp</item>
<item name="android:layout_marginBottom">8dp</item>
</style>

<style name="DeptItemSelected">
<item name="android:background">@drawable/bg_dept_selected</item>
<item name="android:textColor">@android:color/white</item>
<item name="android:padding">12dp</item>
<item name="android:layout_marginBottom">8dp</item>
</style>

<style name="TimeAvailable">
<item name="android:background">@drawable/bg_time_available</item>
<item name="android:padding">10dp</item>
<item name="android:layout_margin">6dp</item>
</style>

<style name="TimeBooked">
<item name="android:background">@drawable/bg_time_booked</item>
</style>

<style name="TimeSelected">
    <item name="android:background">@drawable/bg_time_selected</item>
</style>
</resources>