<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- Date Block -->
        <LinearLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#F6F8FB"
            android:layout_marginEnd="16dp">

            <TextView
                android:id="@+id/appointmentMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="APR"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#3A7AFE"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/appointmentDay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="24"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/appointmentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30"
                android:textSize="12sp"
                android:textColor="#6B7280"/>
        </LinearLayout>

        <!-- Details -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/appointmentTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Neurological Follow-up"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#111827"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/appointmentDoctor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Sarah Chen"
                android:textSize="14sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/appointmentLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="King Faisal Hospital"
                android:textSize="12sp"
                android:textColor="#6B7280"
                android:layout_marginBottom="12dp"/>

            <!-- Status Badge -->
            <TextView
                android:id="@+id/appointmentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Confirmed"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="#22C55E"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfirm"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Confirm"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:backgroundTint="#22C55E"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReschedule"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Reschedule"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#EEF2F7"
                    app:strokeWidth="1dp"
                    android:textColor="#6B7280"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textSize="13sp"
                    app:cornerRadius="12dp"
                    app:strokeColor="#FEE2E2"
                    app:strokeWidth="1dp"
                    android:textColor="#EF4444"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
