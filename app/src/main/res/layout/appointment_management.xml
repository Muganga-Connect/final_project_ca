<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FB">

    <!-- Main ScrollView -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bookAppointmentButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Top Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Next Checkup -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="12dp"
                            app:cardElevation="2dp"
                            app:cardBackgroundColor="#F0F9FF">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_calendar_checkup"
                                android:tint="#3A7AFE"
                                android:layout_gravity="center"/>
                        </com.google.android.material.card.MaterialCardView>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Next Checkup"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/nextCheckupTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tomorrow 10:30"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>
                    </LinearLayout>

                    <!-- Health Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="#E5E7EB"/>

                            <View
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/circular_progress"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="92"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#111827"
                                android:layout_gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health Score"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Search Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="26dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#EEF2F7">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:tint="#6B7280"
                        android:layout_marginEnd="12dp"/>

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Search hospitals, clinics..."
                        android:textSize="14sp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:background="@android:color/transparent"
                        android:inputType="text"/>

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_filter"
                        android:tint="#3A7AFE"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Recent Hospitals -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Hospitals"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- King Faisal Hospital -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/chipKingFaisal"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_hospital"
                                    android:tint="#3A7AFE"
                                    android:layout_marginEnd="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="King Faisal"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="#111827"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Rwanda Military Hospital -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/chipRwandaMilitary"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            android:layout_marginEnd="12dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_hospital"
                                    android:tint="#3A7AFE"
                                    android:layout_marginEnd="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Military"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="#111827"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- CHUK Hospital -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/chipCHUK"
                            android:layout_width="wrap_content"
                            android:layout_height="60dp"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="3dp"
                            app:cardBackgroundColor="#FFFFFF">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:padding="16dp">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_hospital"
                                    android:tint="#3A7AFE"
                                    android:layout_marginEnd="8dp"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="CHUK"
                                    android:textSize="13sp"
                                    android:textStyle="bold"
                                    android:textColor="#111827"/>
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 4. Stepper -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/stepperCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Step Indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="24dp">

                        <!-- Step 1: Department -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <FrameLayout
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginBottom="8dp">

                                <View
                                    android:layout_width="28dp"
                                    android:layout_height="28dp"
                                    android:background="@drawable/step_active_circle"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="1"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="#FFFFFF"
                                    android:layout_gravity="center"/>
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Department"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#3A7AFE"/>
                        </LinearLayout>

                        <!-- Connector Line -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:layout_weight="1"
                            android:background="#E5E7EB"
                            android:layout_marginHorizontal="8dp"/>

                        <!-- Step 2: Specialist -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <View
                                android:id="@+id/specialistStepCircle"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/step_inactive_circle"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Specialist"
                                android:textSize="12sp"
                                android:textColor="#6B7280"/>
                        </LinearLayout>

                        <!-- Connector Line -->
                        <View
                            android:layout_width="0dp"
                            android:layout_height="2dp"
                            android:layout_weight="1"
                            android:background="#E5E7EB"
                            android:layout_marginHorizontal="8dp"/>

                        <!-- Step 3: Time Slot -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <View
                                android:id="@+id/timeSlotStepCircle"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:background="@drawable/step_inactive_circle"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Time Slot"
                                android:textSize="12sp"
                                android:textColor="#6B7280"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- 5. Department Selection -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Department"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111827"
                            android:layout_marginBottom="16dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/departmentRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- 6. Specialist Selection (Initially Hidden) -->
                    <LinearLayout
                        android:id="@+id/specialistSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available Specialists"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111827"
                            android:layout_marginBottom="16dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/specialistRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <!-- 7. Time Slot Selection (Initially Hidden) -->
                    <LinearLayout
                        android:id="@+id/timeSlotSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="24dp">

                        <!-- Date Selector -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Date"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111827"
                            android:layout_marginBottom="16dp"/>

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="20dp"
                            android:scrollbars="none">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/dateApr24"
                                    style="@style/Widget.Material3.Button"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="Apr 24"
                                    android:textSize="13sp"
                                    app:cornerRadius="20dp"
                                    app:backgroundTint="#3A7AFE"
                                    android:textColor="#FFFFFF"
                                    android:layout_marginEnd="8dp"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/dateApr25"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="Apr 25"
                                    android:textSize="13sp"
                                    app:cornerRadius="20dp"
                                    app:strokeColor="#E5E7EB"
                                    app:strokeWidth="1dp"
                                    android:textColor="#6B7280"
                                    android:layout_marginEnd="8dp"/>

                                <com.google.android.material.button.MaterialButton
                                    android:id="@+id/dateApr26"
                                    style="@style/Widget.Material3.Button.OutlinedButton"
                                    android:layout_width="wrap_content"
                                    android:layout_height="40dp"
                                    android:text="Apr 26"
                                    android:textSize="13sp"
                                    app:cornerRadius="20dp"
                                    app:strokeColor="#E5E7EB"
                                    app:strokeWidth="1dp"
                                    android:textColor="#6B7280"/>
                            </LinearLayout>
                        </HorizontalScrollView>

                        <!-- Time Grid -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Select Time"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111827"
                            android:layout_marginBottom="16dp"/>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/timeSlotRecyclerView"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 8. AI Recommendation Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/aiRecommendationCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#F0F9FF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_ai_spark"
                        android:tint="#3A7AFE"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best time for you: 10:30 AM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#3A7AFE"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Low no-show risk"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:background="#F0FDF4"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 9. Care Hub Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/careHubCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Pill Tabs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#F3F4F6"
                        android:padding="4dp"
                        android:weightSum="3"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/tabUpcoming"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="#3A7AFE"
                            android:gravity="center"
                            android:padding="12dp"/>

                        <TextView
                            android:id="@+id/tabRescheduled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rescheduled"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="12dp"/>

                        <TextView
                            android:id="@+id/tabCancelled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancelled"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="12dp"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/appointmentRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- 10. Primary CTA Button (Green Gradient) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/bookAppointmentButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Book Appointment"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/green_gradient_button"
        app:cornerRadius="28dp"
        app:strokeWidth="0dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 11. Bottom Navigation -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavigation"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:cardBackgroundColor="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="24dp">

            <!-- Home Tab -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="#6B7280"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Home"
                    android:textSize="10sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <!-- Schedule Tab (Active) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_marginBottom="4dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="#3A7AFE">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar_checkup"
                        android:tint="#FFFFFF"
                        android:layout_gravity="center"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:textColor="#3A7AFE"/>
            </LinearLayout>

            <!-- Profile Tab -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_profile"
                    android:tint="#6B7280"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="10sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>

            <!-- AI Tab -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <ImageView
                    android:layout_width="24dp"
                    android:height="24dp"
                    android:src="@drawable/ic_ai_spark"
                    android:tint="#6B7280"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI"
                    android:textSize="10sp"
                    android:textColor="#6B7280"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
