<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D7EDFF">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Top Health Summary Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/healthSummaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E3F2FD">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_menu"
                            app:tint="#1E88E5"/>
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NEXT CHECKUP"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#8AA6C7"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tomorrow, 10:30 AM"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#1A4C91"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HEALTH SCORE"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#8AA6C7"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92/100"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#F57C00"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Search Bar -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                app:cardCornerRadius="27dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:paddingStart="20dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@android:drawable/ic_menu_search"
                        app:tint="#B0C4DE"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Search for hospital or clinic"
                        android:textColor="#B0C4DE"
                        android:textSize="15sp"
                        android:layout_marginStart="12dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Hospital -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Hospital"
                android:textStyle="bold"
                android:textColor="#1A4C91"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:layout_marginBottom="24dp">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/hospitalCityGeneral"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="City General Hospital"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@android:color/white"
                        android:textColor="#1A4C91"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/hospitalMayo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Mayo Clinic"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@android:color/white"
                        android:textColor="#1A4C91"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <TextView
                        android:id="@+id/hospitalStMarys"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="St. Mary's"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:background="@android:color/white"
                        android:textColor="#1A4C91"
                        android:textSize="12sp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Step 01: Department -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="2dp"
                app:strokeColor="#1E88E5"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_menu"
                            app:tint="#1E88E5"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step 01"
                            android:layout_alignParentEnd="true"
                            android:background="#E3F2FD"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textColor="#1E88E5"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Department"
                        android:textStyle="bold"
                        android:textColor="#1A4C91"
                        android:textSize="18sp"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Choose clinical specialty"
                        android:textColor="#8AA6C7"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <TextView
                        android:id="@+id/deptCardiology"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Cardiology"
                        android:padding="12dp"
                        android:background="#F5F9FD"
                        android:textColor="#1A4C91"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/deptNeurology"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Neurology"
                        android:padding="12dp"
                        android:background="#1E88E5"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 02: Specialist -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_account"
                            app:tint="#1E88E5"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step 02"
                            android:layout_alignParentEnd="true"
                            android:background="#E3F2FD"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textColor="#1E88E5"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Specialist"
                        android:textStyle="bold"
                        android:textColor="#1A4C91"
                        android:textSize="18sp"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select preferred provider"
                        android:textColor="#8AA6C7"
                        android:textSize="12sp"
                        android:layout_marginBottom="12dp"/>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/specialistCard"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E3F2FD">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">
                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_account"
                                app:shapeAppearanceOverlay="@style/CircleImage"/>
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Dr. Sarah Chen"
                                    android:textStyle="bold"
                                    android:textColor="#1A4C91"
                                    android:textSize="14sp"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Available Today"
                                    android:textColor="#8AA6C7"
                                    android:textSize="10sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Step 03: Time Slot -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="2dp"
                app:strokeColor="#F57C00"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_menu"
                            app:tint="#F57C00"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Step 03"
                            android:layout_alignParentEnd="true"
                            android:background="#FFF3E0"
                            android:paddingHorizontal="8dp"
                            android:paddingVertical="4dp"
                            android:textColor="#F57C00"
                            android:textSize="10sp"
                            android:textStyle="bold"/>
                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Time Slot"
                        android:textStyle="bold"
                        android:textColor="#1A4C91"
                        android:textSize="18sp"
                        android:layout_marginTop="12dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="finalize your visit"
                        android:textColor="#8AA6C7"
                        android:textSize="12sp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectSession"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Select Session"
                        app:cornerRadius="12dp"
                        android:textAllCaps="false"
                        android:backgroundTint="#1E88E5"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Your Care Hub -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Care Hub"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1A4C91"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:id="@+id/hubTabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">
                <TextView
                    android:id="@+id/tabUpcoming"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Upcoming"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:background="#FFFFFF"
                    android:textColor="#1E88E5"
                    android:textStyle="bold"/>
                <TextView
                    android:id="@+id/tabRescheduled"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Rescheduled"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:textColor="#8AA6C7"/>
                <TextView
                    android:id="@+id/tabCancelledHub"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cancelled"
                    android:gravity="center"
                    android:paddingVertical="10dp"
                    android:textColor="#8AA6C7"/>
            </LinearLayout>

            <!-- Appointment Card 1 -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/appointmentCard1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="4dp"
                app:strokeColor="#1E88E5"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="#E3F2FD">
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NOV"
                                android:textSize="10sp"
                                android:textColor="#1E88E5"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WED"
                                android:textSize="10sp"
                                android:textColor="#1A4C91"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Neurological Follow-up"
                        android:textStyle="bold"
                        android:textColor="#1A4C91"
                        android:textSize="18sp"
                        android:layout_marginTop="16dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Sarah Chen"
                        android:textColor="#8AA6C7"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:30 AM"
                            android:textColor="#1A4C91"
                            android:textSize="12sp"
                            android:drawablePadding="4dp"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Building B, Room 402"
                            android:textColor="#1A4C91"
                            android:textSize="12sp"
                            android:layout_marginStart="16dp"
                            android:drawablePadding="4dp"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirmPresence"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Confirm Presence"
                        app:cornerRadius="8dp"
                        android:backgroundTint="#E8F5E9"
                        android:textColor="#4CAF50"
                        android:textAllCaps="false"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnReschedule"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reschedule"
                            app:cornerRadius="8dp"
                            android:backgroundTint="#FFF3E0"
                            android:textColor="#F57C00"
                            android:textAllCaps="false"
                            android:layout_marginEnd="8dp"/>
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancel"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancel"
                            app:cornerRadius="8dp"
                            android:backgroundTint="#FFEBEE"
                            android:textColor="#E53935"
                            android:textAllCaps="false"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom Nav -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/bottomNavCard"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        app:cardElevation="8dp"
        app:cardCornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="center">

            <LinearLayout
                android:id="@+id/navDashboard"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu"
                    app:tint="#8AA6C7"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dashboard"
                    android:textSize="10sp"
                    android:textColor="#8AA6C7"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navSchedule"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="60dp"
                    android:layout_height="36dp"
                    app:cardCornerRadius="18dp"
                    app:cardBackgroundColor="#1E88E5"
                    app:cardElevation="0dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_menu"
                        app:tint="#FFFFFF"/>
                </com.google.android.material.card.MaterialCardView>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Schedule"
                    android:textSize="10sp"
                    android:textColor="#1E88E5"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navAI"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_account"
                    app:tint="#8AA6C7"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Assistant"
                    android:textSize="10sp"
                    android:textColor="#8AA6C7"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/navProfile"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_account"
                    app:tint="#8AA6C7"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile"
                    android:textSize="10sp"
                    android:textColor="#8AA6C7"/>
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
