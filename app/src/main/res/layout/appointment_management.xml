<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Card (Hero Section) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/heroCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Welcome Section -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="WELCOME BACK"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="#8AA6C7"
                                android:letterSpacing="0.1"/>

                            <TextView
                                android:id="@+id/userNameText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chloe Harrison"
                                android:textSize="24sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <!-- Profile Image -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            app:cardCornerRadius="32dp"
                            app:cardElevation="4dp"
                            app:strokeWidth="3dp"
                            app:strokeColor="#4A90E2">
                            <ImageView
                                android:id="@+id/profileImage"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:src="@android:drawable/ic_menu_camera"
                                android:scaleType="centerCrop"
                                android:background="#E3F2FD"/>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>

                    <!-- Health Stats Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- Weight -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="#4A90E2"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="68 kg"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Weight"
                                android:textSize="10sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>

                        <!-- Height -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_menu_more"
                                app:tint="#4A90E2"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="170 cm"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Height"
                                android:textSize="10sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>

                        <!-- Blood Type -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#4A90E2"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O+"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Type"
                                android:textSize="10sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>

                        <!-- Health Score -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="8dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="#4CAF50"
                                android:layout_marginBottom="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="92/100"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Score"
                                android:textSize="10sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Smart Alert Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/smartAlertCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFF8F0"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#FF9800"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Smart Alert"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#1A4C91"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Based on your recent activity, consider scheduling a follow-up checkup within the next 2 weeks for optimal health monitoring."
                        android:textSize="14sp"
                        android:textColor="#5A6C7D"
                        android:lineSpacingExtra="2dp"
                        android:layout_marginBottom="16dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnScheduleCheckup"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Schedule Checkup"
                        app:cornerRadius="16dp"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:backgroundTint="#FF9800"
                        app:strokeWidth="0dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Upcoming Appointment Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/upcomingAppointmentCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Upcoming Appointment"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#4A90E2"
                        android:background="#E3F2FD"
                        android:padding="8dp"
                        android:layout_marginBottom="16dp"/>

                    <!-- Appointment Details -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="16dp">
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. Sarah Chen"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginBottom="4dp"/>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Neurology Specialist"
                                android:textSize="14sp"
                                android:textColor="#8AA6C7"
                                android:layout_marginBottom="8dp"/>
                            
                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <ImageView
                                    android:layout_width="16dp"
                                    android:layout_height="16dp"
                                    android:src="@android:drawable/ic_menu_recent_history"
                                    app:tint="#8AA6C7"/>
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Nov 24, 2024 at 10:30 AM"
                                    android:textSize="14sp"
                                    android:textColor="#1A4C91"
                                    android:layout_marginStart="4dp"/>
                            </LinearLayout>
                        </LinearLayout>
                        
                        <!-- Status Badge -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CONFIRMED"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="#4CAF50"
                            android:padding="8dp"/>
                    </LinearLayout>

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRescheduleAppointment"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Reschedule"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:backgroundTint="#E3F2FD"
                            android:textColor="#4A90E2"
                            android:layout_marginEnd="8dp"/>
                        
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnCancelAppointment"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="Cancel"
                            app:cornerRadius="12dp"
                            android:textAllCaps="false"
                            android:textSize="14sp"
                            android:backgroundTint="#FFEBEE"
                            android:textColor="#F44336"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Health Metrics Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/healthMetricsCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#4A90E2"/>
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Health Metrics"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A4C91"
                            android:layout_marginStart="8dp"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View All"
                            android:textSize="14sp"
                            android:textColor="#4A90E2"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"/>
                    </LinearLayout>

                    <!-- Blood Pressure -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA"
                        android:layout_marginBottom="8dp">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_recent_history"
                                app:tint="#4A90E2"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Pressure"
                                android:textSize="14sp"
                                android:textColor="#1A4C91"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="120/80"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OPTIMAL"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:background="#4CAF50"
                                android:padding="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↓"
                                android:textSize="12sp"
                                android:textColor="#4CAF50"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Heart Rate -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA"
                        android:layout_marginBottom="8dp">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="#4A90E2"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Heart Rate"
                                android:textSize="14sp"
                                android:textColor="#1A4C91"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="72 bpm"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="OPTIMAL"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:background="#4CAF50"
                                android:padding="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="→"
                                android:textSize="12sp"
                                android:textColor="#4CAF50"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Blood Sugar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA">
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_info_details"
                                app:tint="#4A90E2"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Sugar"
                                android:textSize="14sp"
                                android:textColor="#1A4C91"
                                android:layout_marginStart="8dp"/>
                        </LinearLayout>
                        
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginStart="16dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="95 mg/dL"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginEnd="8dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ELEVATED"
                                android:textSize="10sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:background="#FF9800"
                                android:padding="4dp"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="↑"
                                android:textSize="12sp"
                                android:textColor="#FF9800"
                                android:layout_marginStart="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Reminders Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/remindersCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:layout_marginBottom="24dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Section Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">
                        
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="#4A90E2"/>
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Reminders"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#1A4C91"
                            android:layout_marginStart="8dp"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Add New"
                            android:textSize="14sp"
                            android:textColor="#4A90E2"
                            android:background="?android:attr/selectableItemBackgroundBorderless"
                            android:padding="4dp"/>
                    </LinearLayout>

                    <!-- Reminder Item 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_camera"
                            app:tint="#4A90E2"
                            android:layout_marginEnd="12dp"/>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Metformin 500mg"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginBottom="2dp"/>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Twice daily - After meals"
                                android:textSize="12sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>
                        
                        <CheckBox
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#4A90E2"/>
                    </LinearLayout>

                    <!-- Reminder Item 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA"
                        android:layout_marginBottom="8dp">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_info_details"
                            app:tint="#4A90E2"
                            android:layout_marginEnd="12dp"/>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Pressure Check"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginBottom="2dp"/>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Daily at 8:00 AM"
                                android:textSize="12sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>
                        
                        <CheckBox
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#4A90E2"
                            android:checked="true"/>
                    </LinearLayout>

                    <!-- Reminder Item 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="#F8F9FA">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            app:tint="#4A90E2"
                            android:layout_marginEnd="12dp"/>
                        
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Doctor Appointment"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#1A4C91"
                                android:layout_marginBottom="2dp"/>
                            
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nov 24 at 10:30 AM"
                                android:textSize="12sp"
                                android:textColor="#8AA6C7"/>
                        </LinearLayout>
                        
                        <CheckBox
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="#4A90E2"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <include
        layout="@layout/include_bottom_nav"
        android:id="@+id/bottomBar"
        android:layout_width="0dp"
        android:layout_height="72dp"
        android:layout_marginBottom="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
