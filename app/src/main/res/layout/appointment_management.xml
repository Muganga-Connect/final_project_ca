<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6FB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ============================================================ -->
        <!--  TOP HEADER CARD  (Next Checkup + Health Score)              -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#FFFFFF"
            android:paddingStart="16dp"
            android:paddingTop="40dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Hamburger icon + Next Checkup label -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivMenu"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu"
                    android:contentDescription="Menu" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Next CHECKUP"
                    android:textColor="#9AA5B4"
                    android:textSize="11sp"
                    android:letterSpacing="0.08"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/tvNextCheckup"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tomorrow, 10:30 AM"
                    android:textColor="#1A2340"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <!-- Health Score circular indicator -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <!-- Use a custom view or ProgressBar for arc; fallback TextView here -->
                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/circularHealth"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    app:indicatorColor="#F5A623"
                    app:trackColor="#F0F2F5"
                    app:trackThickness="6dp"
                    app:indicatorSize="80dp"
                    android:progress="92" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health Score"
                        android:textColor="#9AA5B4"
                        android:textSize="8sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="92/100"
                        android:textColor="#1A2340"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>

        <!-- ============================================================ -->
        <!--  SEARCH BAR                                                   -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:contentDescription="Search" />

            <EditText
                android:id="@+id/etSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@null"
                android:hint="Search for hospital or clinic..."
                android:textColorHint="#B0BAC9"
                android:textColor="#1A2340"
                android:textSize="13sp"
                android:paddingStart="8dp"
                android:importantForAutofill="no"
                android:inputType="text" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_filter"
                android:contentDescription="Filter" />
        </LinearLayout>

        <!-- ============================================================ -->
        <!--  RECENT HOSPITALS                                             -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recent Hospital"
                android:textColor="#1A2340"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvViewAllHospitals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="View all"
                android:textColor="#3D7FE8"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Hospital chips row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="16dp"
            android:paddingTop="8dp"
            android:paddingEnd="16dp"
            android:orientation="horizontal"
            android:weightSum="3">

            <!-- City General Hospital -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_hospital_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_hospital"
                    android:contentDescription="Hospital" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="City General\nHospital"
                    android:gravity="center"
                    android:textColor="#1A2340"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Mayo Clinic -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_hospital_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_hospital"
                    android:contentDescription="Hospital" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Mayo Clinic"
                    android:gravity="center"
                    android:textColor="#1A2340"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- St. Mary's Hospital -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_hospital_chip"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="10dp">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_hospital"
                    android:contentDescription="Hospital" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="St. Mary's\nHospital"
                    android:gravity="center"
                    android:textColor="#1A2340"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================================================ -->
        <!--  STEPPER  (Department → Specialist → Time Slot)              -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Step indicators -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Step 1: Department (active/completed) -->
                <TextView
                    android:id="@+id/tvStep1"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_active"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#3D7FE8" />

                <!-- Step 2: Specialist -->
                <TextView
                    android:id="@+id/tvStep2"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#9AA5B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#E0E6EF" />

                <!-- Step 3: Time Slot -->
                <TextView
                    android:id="@+id/tvStep3"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#9AA5B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Step labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Department"
                    android:textColor="#3D7FE8"
                    android:textSize="10sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Specialist"
                    android:textColor="#9AA5B4"
                    android:textSize="10sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Time Slot"
                    android:textColor="#9AA5B4"
                    android:textSize="10sp"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Department section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Department"
                android:textColor="#1A2340"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Choose clinical specialty"
                android:textColor="#9AA5B4"
                android:textSize="12sp" />

            <!-- Cardiology option -->
            <LinearLayout
                android:id="@+id/llCardiology"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_department_item_normal"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_cardiology"
                    android:contentDescription="Cardiology" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Cardiology"
                    android:textColor="#1A2340"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Neurology option (SELECTED) -->
            <LinearLayout
                android:id="@+id/llNeurology"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_department_item_selected"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_neurology"
                    android:contentDescription="Neurology" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="Neurology"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle"
                    android:contentDescription="Selected" />
            </LinearLayout>

            <!-- Dentistry option -->
            <LinearLayout
                android:id="@+id/llDentistry"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_department_item_normal"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_dentistry"
                    android:contentDescription="Dentistry" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Dentistry"
                    android:textColor="#1A2340"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================================================ -->
        <!--  SPECIALIST CARD                                              -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stepper (step 2 now active) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Step 1 completed -->
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_step_completed"
                    android:contentDescription="Completed" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#3D7FE8" />

                <!-- Step 2 active -->
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_active"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#E0E6EF" />

                <!-- Step 3 inactive -->
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#9AA5B4"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Specialist section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Specialist"
                android:textColor="#1A2340"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Select preferred provider"
                android:textColor="#9AA5B4"
                android:textSize="12sp" />

            <!-- Doctor card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_doctor_card"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Doctor avatar -->
                <ImageView
                    android:id="@+id/ivDoctorAvatar"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/img_doctor_sarah"
                    android:background="@drawable/bg_dot_green"
                    android:padding="2dp"
                    android:contentDescription="Doctor" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvDoctorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Sarah Chen"
                        android:textColor="#1A2340"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Neurologist"
                        android:textColor="#9AA5B4"
                        android:textSize="12sp" />

                    <!-- Available indicator -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:background="@drawable/bg_dot_green" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:text="Available Today"
                            android:textColor="#27AE60"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Star rating -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:src="@drawable/ic_star"
                        android:contentDescription="Star" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="4.5"
                        android:textColor="#F5A623"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Choose another doctor row -->
            <LinearLayout
                android:id="@+id/llChooseAnotherDoctor"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_outline_row"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Choose another doctor"
                    android:textColor="#9AA5B4"
                    android:textSize="13sp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_chevron_right"
                    android:contentDescription="Navigate" />
            </LinearLayout>
        </LinearLayout>

        <!-- ============================================================ -->
        <!--  TIME SLOT CARD                                               -->
        <!-- ============================================================ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_card_white"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stepper (all steps done / step 3 active) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_step_completed"
                    android:contentDescription="Completed" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#3D7FE8" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_step_completed"
                    android:contentDescription="Completed" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="2dp"
                    android:layout_weight="1"
                    android:background="#3D7FE8" />

                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_active"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Step label for Time Slot -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="" android:textSize="10sp" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:gravity="center"
                    android:text="Time Slot" android:textColor="#3D7FE8"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- Time Slot section title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Time Slot"
                android:textColor="#1A2340"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Finalize your visit"
                android:textColor="#9AA5B4"
                android:textSize="12sp" />

            <!-- Day picker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Sun 22 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Sun" android:textColor="#9AA5B4" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="22" android:textColor="#9AA5B4" android:textSize="14sp"
                        android:textStyle="bold" android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Mon 23 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Mon" android:textColor="#9AA5B4" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="23" android:textColor="#9AA5B4" android:textSize="14sp"
                        android:textStyle="bold" android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Tue 24 SELECTED -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_day_selected"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tue" android:textColor="#FFFFFF" android:textSize="10sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
