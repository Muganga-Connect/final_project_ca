<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FB">

    <!-- Main ScrollView -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/confirmButton"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 1. Top Summary Card (Glassy Elevated) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#FFFFFF"
                android:background="@drawable/glassy_gradient">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="20dp">

                    <!-- Next Checkup -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_calendar_checkup"
                            android:tint="#3A7AFE"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Next Checkup"
                            android:textSize="12sp"
                            android:textColor="#6B7280"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/nextCheckupTime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tomorrow 10:30"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="#111827"/>
                    </LinearLayout>

                    <!-- Health Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="#E5E7EB"/>

                            <View
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:background="@drawable/circular_progress"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="92"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#111827"
                                android:layout_gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health Score"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Search Bar (Pill Shape) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:tint="#6B7280"
                        android:layout_marginEnd="12dp"/>

                    <EditText
                        android:id="@+id/searchEditText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:hint="Search doctors, hospitals..."
                        android:textSize="14sp"
                        android:textColor="#111827"
                        android:textColorHint="#9CA3AF"
                        android:background="@android:color/transparent"
                        android:inputType="text"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 3. Recent Hospitals (Soft Chips) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Hospitals"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipKingFaisal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="King Faisal Hospital"
                            app:chipBackgroundColor="#F3F4F6"
                            app:chipIcon="@drawable/ic_hospital"
                            app:chipIconTint="#6B7280"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipRwandaMilitary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rwanda Military Hospital"
                            app:chipBackgroundColor="#3A7AFE"
                            app:chipIcon="@drawable/ic_hospital"
                            app:chipIconTint="#FFFFFF"
                            android:layout_marginEnd="8dp"/>

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCHUK"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CHUK Hospital"
                            app:chipBackgroundColor="#F3F4F6"
                            app:chipIcon="@drawable/ic_hospital"
                            app:chipIconTint="#6B7280"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- 4. Progress Stepper (Top) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/progressCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="20dp"
                    android:weightSum="4">

                    <!-- Doctor Step -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_marginBottom="8dp">

                            <View
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:background="@drawable/step_completed_circle"/>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_check"
                                android:tint="#FFFFFF"
                                android:layout_gravity="center"/>
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doctor"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#22C55E"/>
                    </LinearLayout>

                    <!-- Date Step -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <View
                            android:id="@+id/dateStepCircle"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/step_active_circle"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Date"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:textColor="#3A7AFE"/>
                    </LinearLayout>

                    <!-- Time Step -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <View
                            android:id="@+id/timeStepCircle"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/step_inactive_circle"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>

                    <!-- Confirm Step -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <View
                            android:id="@+id/confirmStepCircle"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/step_inactive_circle"
                            android:layout_marginBottom="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Confirm"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 5. Department Selection (Cards/Chips) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Department"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#111827"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnCardiology"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Cardiology"
                        android:textSize="13sp"
                        app:cornerRadius="20dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp"
                        android:textColor="#6B7280"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnNeurology"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Neurology"
                        android:textSize="13sp"
                        app:cornerRadius="20dp"
                        app:backgroundTint="#3A7AFE"
                        android:textColor="#FFFFFF"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDentistry"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Dentistry"
                        android:textSize="13sp"
                        app:cornerRadius="20dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp"
                        android:textColor="#6B7280"
                        android:layout_marginEnd="4dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPediatrics"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Pediatrics"
                        android:textSize="13sp"
                        app:cornerRadius="20dp"
                        app:strokeColor="#E5E7EB"
                        app:strokeWidth="1dp"
                        android:textColor="#6B7280"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 6. Doctor Selection (Upgraded Cards) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/doctorSelectionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Available Doctors"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/doctorRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 7. Time Slot Section (Grid) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/timeSlotCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Time Slot"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#111827"
                        android:layout_marginBottom="16dp"/>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/timeSlotRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 8. AI Suggestion Card (Elegant) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/aiSuggestionCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                android:background="@drawable/ai_suggestion_gradient"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_ai_spark"
                        android:tint="#3A7AFE"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Recommendation"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#3A7AFE"
                            android:layout_marginBottom="4dp"/>

                        <TextView
                            android:id="@+id/aiRecommendationText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Best time: Tomorrow 10:30 AM • Low no-show risk"
                            android:textSize="12sp"
                            android:textColor="#6B7280"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 9. Care Hub (Appointments Section) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/careHubCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#FFFFFF">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Pill Tabs -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#F3F4F6"
                        android:padding="4dp"
                        android:weightSum="3"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/tabUpcoming"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Upcoming"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:background="#3A7AFE"
                            android:gravity="center"
                            android:padding="12dp"/>

                        <TextView
                            android:id="@+id/tabRescheduled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Rescheduled"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="12dp"/>

                        <TextView
                            android:id="@+id/tabCancelled"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Cancelled"
                            android:textSize="14sp"
                            android:textColor="#6B7280"
                            android:gravity="center"
                            android:padding="12dp"/>
                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/appointmentRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <!-- 10. Primary CTA (Single Strong Button) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/confirmButton"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Confirm Appointment"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#3A7AFE"
        app:cornerRadius="24dp"
        app:strokeWidth="0dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
