<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/signupRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <!-- App Title -->
            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MugangaConnect+"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="60dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tvTagline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Healthcare access, unified."
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/tvAppTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:layout_constraintTop_toBottomOf="@id/tvTagline"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!--Tab Switcher -->
                    <LinearLayout
                        android:id="@+id/tabContainer"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:background="@drawable/bg_tab_unselected"
                        android:padding="4dp">

                        <!-- Login Tab unselected -->
                        <LinearLayout
                            android:id="@+id/tabLogin"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tab_unselected"
                            android:clickable="true"
                            android:focusable="true">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_login_arrow"
                                app:tint="@color/text_hint"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Login"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint"/>
                        </LinearLayout>

                        <!-- Sign Up Tab selected -->
                        <LinearLayout
                            android:id="@+id/tabSignUp"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_tab_selected">

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_person_add"
                                app:tint="@color/blue_primary"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sign Up"
                                android:textSize="12sp"
                                android:textColor="@color/blue_primary"
                                android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Personal Information Title  -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal Information"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="20dp"/>

                    <!-- Full Names -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FULL NAMES"
                        style="@style/EditTextLabel"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_person"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter credentials"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:inputType="textPersonName"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <!-- Phone or Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PHONE OR EMAIL"
                        style="@style/EditTextLabel"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:src="@drawable/ic_person"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etSignUpEmail"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Enter credentials"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:inputType="textEmailAddress"
                            android:singleLine="true"/>
                    </LinearLayout>

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PASSWORD"
                        style="@style/EditTextLabel"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etSignUpPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="••••••••"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:inputType="textPassword"
                            android:singleLine="true"/>

                        <ImageView
                            android:id="@+id/ivPasswordToggle"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_eye"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- Confirm Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CONFIRM PASSWORD"
                        style="@style/EditTextLabel"
                        android:layout_marginBottom="6dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:background="@drawable/bg_edittext"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_marginBottom="24dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_lock"
                            android:layout_marginEnd="10dp"/>

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="••••••••"
                            android:textColorHint="@color/text_hint"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"
                            android:inputType="textPassword"
                            android:singleLine="true"/>

                        <ImageView
                            android:id="@+id/ivConfirmPasswordToggle"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_eye"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                    <!-- Divider -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="16dp">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/divider"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  SECURE ACCESS  "
                            android:textSize="10sp"
                            android:textColor="@color/text_hint"
                            android:letterSpacing="0.1"/>

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/divider"/>
                    </LinearLayout>

                    <!-- Sign Up Button -->
                    <Button
                        android:id="@+id/btnSignUp"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:text="Sign-up →"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_button_blue"
                        android:stateListAnimator="@null"
                        android:layout_marginBottom="12dp"/>

                    <!-- Biometrics -->
                    <LinearLayout
                        android:id="@+id/btnBiometric"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:background="@drawable/bg_biometric_btn"
                        android:clickable="true"
                        android:focusable="true"
                        android:layout_marginBottom="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/fingerprint"
                            android:layout_marginEnd="10dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use Biometrics"
                            android:textColor="@color/text_dark"
                            android:textSize="14sp"/>
                    </LinearLayout>

                    <!-- Already have account? Login -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Already have an account?"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"/>

                        <TextView
                            android:id="@+id/tvLoginLink"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" Login"
                            android:textSize="13sp"
                            android:textColor="@color/link_blue"
                            android:textStyle="bold"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>